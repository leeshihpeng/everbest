generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// StaffRole ("SALES"|"MANAGER"|"MANAGER_VIEW"|"DRIVER"|"DRIVER_VIEW"|"ADMIN") 與
// OrderStatus ("PENDING"|"SELECTED"|"DISPATCHED"|"COMPLETED") 沿用 String（原本因本機開發用
// SQLite 不支援 enum 才改的，繼續用 String 也完全相容 Postgres，不用改回 enum），
// 型別與驗證交給 packages/shared-types 與應用層（見 apps/api/src/utils/roles.ts）

model Customer {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  address    String
  city       String
  phone      String?
  isPriority Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Staff {
  id          String      @id @default(cuid())
  name        String
  roles       String      // 逗號分隔的 StaffRole 清單（SQLite 不支援陣列型別），見 rolesToArray/rolesToString
  homeAddress String
  homeLat     Float?
  homeLng     Float?
  lineGroupId String?
  salesRegions String?    // 業務人員可選客戶的縣市範圍，逗號分隔（如 "台北市,新北市"）；空值＝不限制
  passwordHash String?    // 簡易登入用（PIN 或密碼雜湊）
  orders      DispatchOrder[] @relation("AssignedDriver")
  notifications Notification[]
  createdAt   DateTime    @default(now())
}

model SystemSetting {
  id             String  @id @default("singleton")
  companyAddress String
  companyLat     Float?
  companyLng     Float?
}

model DispatchOrder {
  id               String              @id @default(cuid())
  deliveryDate     DateTime
  customerCode     String
  customerName     String
  address          String
  phone            String?
  status           String              @default("PENDING")
  isPriority       Boolean             @default(false)
  assignedDriverId String?
  assignedDriver   Staff?              @relation("AssignedDriver", fields: [assignedDriverId], references: [id])
  routeSequence    Int?
  lat              Float?
  lng              Float?
  items            DispatchOrderItem[]
  notifications    Notification[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([deliveryDate, status])
}

model DispatchOrderItem {
  id          String        @id @default(cuid())
  order       DispatchOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId     String
  productName String
  quantity    Int
  checked     Boolean       @default(false) // 送貨人員檢貨（裝車確認）完成標記
}

// 檢驗報告的年份目錄。可由最高權限者手動建立（可為空目錄），
// 匯入報告時也會自動依報告日期建立對應年份。
model ReportYear {
  year      Int      @id
  createdAt DateTime @default(now())
}

// 檢驗報告（PDF 檔案存於資料庫，供業務／主管預覽下載分享，主管可刪除）
model InspectionReport {
  id         String    @id @default(cuid())
  year       Int       // 報告年份分類（對應「2026檢驗報告」等資料夾）
  fileName   String    // 產品名稱（不含 .pdf）
  reportDate DateTime? // 報告日期（PDF 內標示；掃描檔無文字層時可能為空，由主管補填）
  mimeType   String    @default("application/pdf")
  sizeBytes  Int
  content    Bytes     // PDF 檔案內容
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([year])
}

// 輸入許可證（PDF/圖檔存於資料庫）。依產品項目（category，對應來源資料夾名）分類，
// 不分年份；同一產品內依 fileDate 由新到舊排序。
model ImportPermit {
  id        String   @id @default(cuid())
  category  String   // 產品項目，例如「A 杏仁粒」（照抄資料夾名）
  fileName  String   // 檔名（不含副檔名），照抄
  fileDate  DateTime // 檔案日期：取自檔名中的民國日期，取不到則用上傳時間
  mimeType  String   @default("application/pdf")
  sizeBytes Int
  content   Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// 貨運追蹤：新竹／大榮託運明細，依收件地址分北中南三區。
// 欄位涵蓋兩家業者，各自畫面只顯示自己有的欄位（保留原始報表風格）。
model Shipment {
  id          String   @id @default(cuid())
  carrier     String   // 新竹貨運 / 大榮貨運
  region      String   // 北部 / 中部 / 南部 / 未分類
  shipDate    DateTime // 發送（託運）日期
  seq         Int? // 序（大榮）
  trackingNo  String // 查貨號碼 / 託運單號
  station     String // 到著站 / 到站
  stationCode String? // 站碼 / 簡碼
  recipient   String
  pieces      Int
  weight      Float
  cbm         Float? // 才數（大榮）
  voucher     String? // 傳票區分（新竹）
  cod         Float? // 代收貨款（大榮）
  phone       String?
  address     String
  orderNo     String?
  note        String? // 內容品 / 備註
  createdAt   DateTime @default(now())

  @@unique([carrier, trackingNo])
  @@index([carrier, region])
}

// 產品報價單：永遠只保留一份，上傳新檔即整份覆蓋。
// 同時保存原始 PDF（權威依據）與解析出的表格（供 App 內快速查詢）。
model QuoteSheet {
  id         String      @id @default("singleton")
  fileName   String
  mimeType   String      @default("application/pdf")
  sizeBytes  Int
  content    Bytes
  uploadedAt DateTime    @default(now())
  uploadedBy String?
  items      QuoteItem[]
}

model QuoteItem {
  id          String     @id @default(cuid())
  sheet       QuoteSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  sheetId     String
  sortOrder   Int
  code        String
  productName String
  brand       String
  spec        String
  price       String // 可能是區間或「缺貨」，保留原樣不轉數字
  validDate   String
  note        String

  @@index([sheetId, sortOrder])
}

model Notification {
  id        String        @id @default(cuid())
  order     DispatchOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  staff     Staff         @relation(fields: [staffId], references: [id])
  staffId   String
  message   String
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())
}
