# 複製這個檔案為 apps/api/.env 並填入實際值

DATABASE_URL=postgresql://user:pass@localhost:5432/route_scheduler
GOOGLE_MAPS_API_KEY=
LINE_CHANNEL_ACCESS_TOKEN=
# 必填，且務必是隨機長字串（例如 openssl rand -hex 32）。
# 正式環境未設定時服務會拒絕啟動，以免用可預測的密鑰簽發登入憑證。
JWT_SECRET=change-me-to-a-random-string

# 允許呼叫 API 的前端網址，逗號分隔；未設定則不限制來源（正式環境請務必設定）
# 例如：CORS_ORIGINS=https://everbest-web-jade.vercel.app
CORS_ORIGINS=

PORT=4000
